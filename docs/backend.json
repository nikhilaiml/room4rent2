{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the room4rent application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user (matches Firebase Auth UID)."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        },
        "name": {
          "type": "string",
          "description": "Full name of the user."
        },
        "role": {
          "type": "string",
          "description": "Role of the user in the system.",
          "enum": ["tenant", "owner", "admin"]
        },
        "phoneNumber": {
            "type": "string",
            "description": "Phone number of the user."
        }
      },
      "required": ["id", "email", "name", "role", "phoneNumber"]
    },
    "Property": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Property",
      "type": "object",
      "description": "Represents a property listing.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the property."
        },
        "ownerId": {
          "type": "string",
          "description": "Reference to the User who owns the property."
        },
        "title": {
          "type": "string",
          "description": "Title of the property listing."
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the property."
        },
        "city": {
          "type": "string"
        },
        "location": {
          "type": "string",
          "description": "Specific locality or address."
        },
        "price": {
          "type": "number",
          "description": "Monthly rent."
        },
        "propertyType": {
          "type": "string",
          "enum": ["Room", "1BHK", "2BHK", "PG", "Hostel"]
        },
        "amenities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "imageUrls": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "ownerId",
        "title",
        "city",
        "location",
        "price",
        "propertyType"
      ]
    },
    "Enquiry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Enquiry",
      "type": "object",
      "description": "Represents an enquiry made by a tenant for a property.",
      "properties": {
        "id": {
          "type": "string"
        },
        "propertyId": {
          "type": "string"
        },
        "tenantId": {
          "type": "string"
        },
        "ownerId": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "propertyId", "tenantId", "ownerId", "message", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "phone"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profile information."
    },
    "/properties/{propertyId}": {
      "schema": {
        "$ref": "#/entities/Property"
      },
      "description": "Stores all property listings."
    },
    "/properties/{propertyId}/enquiries/{enquiryId}": {
      "schema": {
        "$ref": "#/entities/Enquiry"
      },
      "description": "Stores enquiries for a specific property."
    }
  }
}
