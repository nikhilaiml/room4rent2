rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile data. Only the authenticated user can read or write their own profile.
     * @path /users/{userId}
     * @allow (create) - Authenticated user with ID 'user_abc' can create their profile document at /users/user_abc if request.auth.uid == 'user_abc'.
     * @allow (get, update, delete) - Authenticated user with ID 'user_abc' can get, update, or delete their profile document at /users/user_abc.
     * @deny (create) - Authenticated user with ID 'user_xyz' cannot create a profile document at /users/user_abc.
     * @deny (get, update, delete) - Authenticated user with ID 'user_xyz' cannot get, update, or delete the profile document at /users/user_abc.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource.data != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false; // User listing is disallowed.
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to documents uploaded by a user. Only the owner can read, create, update, or delete their own documents.
     * @path /users/{userId}/documents/{documentId}
     * @allow (create) - Authenticated user 'user_abc' can create a document under /users/user_abc/documents/doc1.
     * @allow (get, list, update, delete) - Authenticated user 'user_abc' can get, list, update, or delete the document /users/user_abc/documents/doc1.
     * @deny (create) - Authenticated user 'user_xyz' cannot create a document under /users/user_abc/documents/doc1.
     * @deny (get, list, update, delete) - Authenticated user 'user_xyz' cannot get, list, update, or delete the document /users/user_abc/documents/doc1.
     * @principle Enforces document ownership for writes, restricts listing to owner.
     */
    match /users/{userId}/documents/{documentId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

       function isExistingOwner(userId) {
        return isOwner(userId) && resource.data != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to summaries of documents. Only the owner of the parent document can read, create, update, or delete summaries.
     * @path /users/{userId}/documents/{documentId}/summaries/{summaryId}
     * @allow (create) - Authenticated user 'user_abc' can create a summary under /users/user_abc/documents/doc1/summaries/sum1.
     * @allow (get, list, update, delete) - Authenticated user 'user_abc' can get, list, update, or delete the summary /users/user_abc/documents/doc1/summaries/sum1.
     * @deny (create) - Authenticated user 'user_xyz' cannot create a summary under /users/user_abc/documents/doc1/summaries/sum1.
     * @deny (get, list, update, delete) - Authenticated user 'user_xyz' cannot get, list, update, or delete the summary /users/user_abc/documents/doc1/summaries/sum1.
     * @principle Restricts access to a user's own data tree, enforces ownership.
     */
    match /users/{userId}/documents/{documentId}/summaries/{summaryId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource.data != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to citations extracted from documents. Only the owner of the parent document can read, create, update, or delete citations.
     * @path /users/{userId}/documents/{documentId}/citations/{citationId}
     * @allow (create) - Authenticated user 'user_abc' can create a citation under /users/user_abc/documents/doc1/citations/cite1.
     * @allow (get, list, update, delete) - Authenticated user 'user_abc' can get, list, update, or delete the citation /users/user_abc/documents/doc1/citations/cite1.
     * @deny (create) - Authenticated user 'user_xyz' cannot create a citation under /users/user_abc/documents/doc1/citations/cite1.
     * @deny (get, list, update, delete) - Authenticated user 'user_xyz' cannot get, list, update, or delete the citation /users/user_abc/documents/doc1/citations/cite1.
     * @principle Restricts access to a user's own data tree, enforces ownership.
     */
    match /users/{userId}/documents/{documentId}/citations/{citationId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource.data != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }
  }
}